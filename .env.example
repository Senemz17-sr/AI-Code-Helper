# Supabase Configuration
# Get these from your Supabase project dashboard at https://app.supabase.com
VITE_SUPABASE_PROJECT_ID=your_project_id_here
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key_here

# Stripe Configuration (Optional - for payment features)
VITE_STRIPE_PUBLIC_KEY=your_stripe_public_key_here

# Lovable AI API Key (for code analysis)
# Get this from your Lovable account dashboard
LOVABLE_API_KEY=your_lovable_api_key_here

